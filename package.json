{
	"name": "mayaspace-plugin",
	"version": "0.5.0",
	"description": "Obsidian plugin for the MayaSpace collaborative editing server.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "jest",
		"test:watch": "jest --watch",
		"install:vault": "bash scripts/install.sh",
		"deploy": "npm run build && bash scripts/install.sh"
	},
	"keywords": [
		"obsidian-plugin",
		"mayaspace",
		"collaboration",
		"yjs",
		"hocuspocus",
		"crdt"
	],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"@types/node": "^20.10.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.21.0",
		"fake-indexeddb": "^6.2.5",
		"jest": "^30.4.2",
		"jest-environment-jsdom": "^30.4.1",
		"obsidian": "latest",
		"ts-jest": "^29.4.11",
		"tslib": "^2.6.0",
		"typescript": "^5.4.0"
	},
	"dependencies": {
		"@hocuspocus/provider": "^4.1.0",
		"lib0": "^0.2.117",
		"y-codemirror.next": "^0.3.0",
		"y-indexeddb": "^9.0.12",
		"y-protocols": "^1.0.7",
		"yjs": "^13.6.0"
	}
}
